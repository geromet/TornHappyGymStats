@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var current = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(current) ? "/" : $"/{current}";
        var encoded = Uri.EscapeDataString(returnUrl);
        Navigation.NavigateTo($"/login?returnUrl={encoded}", forceLoad: false);
    }
}
