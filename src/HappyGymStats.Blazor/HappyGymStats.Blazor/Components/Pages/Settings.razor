@page "/settings"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Settings · Happy Gym Stats</PageTitle>

<MudPaper Class="pa-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Settings</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        User and environment preferences.
    </MudText>

    <MudStack Spacing="2" Style="max-width:700px;">
        <MudTextField T="string" Label="API base URL" Placeholder="https://api.happygymstats.dev" Variant="Variant.Outlined" />
        <MudSelect T="string" Label="Theme" Variant="Variant.Outlined" Value="@("Night Ops")" Disabled="true">
            <MudSelectItem T="string" Value="@("Night Ops")">Night Ops (default)</MudSelectItem>
            <MudSelectItem T="string" Value="@("High Contrast")">High Contrast</MudSelectItem>
        </MudSelect>
        <MudSwitch T="bool" Label="Use compact cards" Color="Color.Primary" Value="false" Disabled="true" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true">Save settings</MudButton>
    </MudStack>
</MudPaper>
