@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">Happy Gym Stats</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized Context="authState">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mr-2">
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.VerifiedUser">
                        @(authState.User.Identity?.Name ?? "signed in")
                    </MudChip>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Inherit" OnClick="SignOut">
                        Sign out
                    </MudButton>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login" OnClick="SignIn">
                    Sign in
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
        <MudLink Href="https://www.torn.com" Target="_blank" Color="Color.Inherit">
            <MudText Typo="Typo.caption">Torn City</MudText>
        </MudLink>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Temporary">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="mt-1">Happy Gym Stats</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">Home</MudNavLink>
            <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
            <MudNavLink Href="/player-account" Icon="@Icons.Material.Filled.Person">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <span>Player account</span>
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                </MudStack>
            </MudNavLink>
            <MudNavLink Href="/faction" Icon="@Icons.Material.Filled.Groups">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <span>Faction</span>
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                </MudStack>
            </MudNavLink>
            <MudNavLink Href="/logs" Icon="@Icons.Material.Filled.ReceiptLong">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <span>Logs</span>
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                </MudStack>
            </MudNavLink>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <span>Settings</span>
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                </MudStack>
            </MudNavLink>
            <MudNavLink Href="/terms" Icon="@Icons.Material.Filled.Gavel">Terms of use</MudNavLink>
            <MudNavLink Href="/privacy" Icon="@Icons.Material.Filled.PrivacyTip">Privacy</MudNavLink>
            <MudNavLink Href="/security" Icon="@Icons.Material.Filled.Key">Security</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-4">
            @Body
        </MudContainer>
        <MudDivider />
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-3">
            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                Happy Gym Stats — Data stored locally, never shared externally.
            </MudText>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void SignIn()
    {
        var current = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = Uri.EscapeDataString(string.IsNullOrWhiteSpace(current) ? "/" : $"/{current}");
        Navigation.NavigateTo($"/auth/login?returnUrl={returnUrl}", forceLoad: true);
    }

    private void SignOut()
    {
        Navigation.NavigateTo("/auth/logout?returnUrl=%2F", forceLoad: true);
    }

    private static readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#58a6ff",
            PrimaryContrastText = "#041426",
            Background = "#0b1020",
            BackgroundGray = "#0d1529",
            Surface = "#121a2f",
            AppbarBackground = "#0d1529",
            DrawerBackground = "#0d1529",
            TextPrimary = "#e8f1ff",
            TextSecondary = "#b8e1ff",
            TableLines = "#243457",
            Divider = "#243457",
            LinesDefault = "#243457",
        }
    };
}
