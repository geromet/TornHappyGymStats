anon ALL=(ALL) NOPASSWD: /usr/bin/find
anon ALL=(ALL) NOPASSWD: /bin/mkdir
anon ALL=(ALL) NOPASSWD: /bin/rm
anon ALL=(ALL) NOPASSWD: /bin/ln
anon ALL=(ALL) NOPASSWD: /bin/chown
anon ALL=(ALL) NOPASSWD: /bin/chmod
